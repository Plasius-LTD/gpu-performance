{
  "name": "@plasius/gpu-performance",
  "version": "0.1.0",
  "description": "Device-negotiated GPU performance governor and quality ladder coordination for Plasius rendering stacks.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "legal"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "demo": "tsx demo/example.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:eslint": "eslint . --max-warnings=0",
    "audit:deps": "npm ls --all --omit=optional --omit=peer > /dev/null 2>&1 || true",
    "audit:npm": "npm audit --audit-level=high --omit=dev",
    "audit:test": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build",
    "test:coverage": "vitest run --coverage",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "keywords": [
    "webgpu",
    "performance",
    "governor",
    "adaptive-quality",
    "frame-budget",
    "xr",
    "rendering",
    "typescript",
    "plasius"
  ],
  "author": "Plasius LTD <development@plasius.co.uk>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/gpu-performance.git"
  },
  "bugs": {
    "url": "https://github.com/Plasius-LTD/gpu-performance/issues"
  },
  "homepage": "https://github.com/Plasius-LTD/gpu-performance#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/plasiusltd/membership"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/Plasius-LTD"
    }
  ],
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
